alias cg3207="cd ~/School/cg3207/labs"
# alias in3310="cd ~/School/in3310/labs && source .venv/bin/activate"
alias in3310="cd ~/School/in3310/assignments/ && source .venv/bin/activate && cd 2026\ Mandatory1/"
alias nvimc="cd ~/.config/nvim"
alias reload="source ~/.zshrc"

alias reload-completions="rm -f ~/.zcompdump; compinit"

alias fd="fdfind"

if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
